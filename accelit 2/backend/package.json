{
  "name": "accelit-backend",
  "version": "1.0.0",
  "description": "Accelit Management Platform — Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
