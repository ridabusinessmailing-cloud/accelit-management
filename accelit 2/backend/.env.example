# ============================================================
# Accelit Management — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/accelit_db"

# ── Auth ─────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET="change_this_to_a_long_random_secret_before_deploy"

# ── Server ───────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Frontend origin (for CORS) ───────────────────────────────
FRONTEND_URL=http://localhost:5173
